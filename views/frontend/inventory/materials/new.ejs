<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
  <div class="col-8 offset-2">
    <br />
    <h3>Add New Material</h3>
    <form method="POST" action="/inventory/material" novalidate class="needs-validation">
      <div class="mb-3">
        <label for="name" class="form-label">Name of Material</label>
        <input type="text" name="Material[name]" placeholder="Add a Name" class="form-control" required />
        <div class="invalid-feedback">Name should be valid</div>
      </div>

      <div class="mb-3">
        <label for="supplier" class="form-label">Supplier Name</label>
        <input type="text" name="Material[supplier]" placeholder="e.g Larsen & Toubro" class="form-control" required />
        <div class="invalid-feedback">Supplier should be valid</div>
      </div>

      <div class="row">
        <div class="mb-3 col-md-4">
          <label for="price" class="form-label">Price</label>
          <input type="number" name="Material[price]" placeholder="e.g. 12000" class="form-control" required />
          <div class="invalid-feedback">Price should be valid</div>
        </div>
      </div>

      <div class="row">
        <div class="mb-3 col-md-4">
          <label for="price" class="form-label">Stock</label>
          <input type="number" name="Material[stock]" placeholder="Qnt" class="form-control" required />
          <div class="invalid-feedback">Stock should be valid</div>
        </div>
      </div>
      <button class="btn btn-dark add-btn mt-3">Add</button>
    </form>
    <br />
  </div>
</div>