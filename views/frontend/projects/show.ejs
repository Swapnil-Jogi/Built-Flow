<% layout("/layouts/boilerplate") %>
<body>
  <div class="row mt-3">
      <div class="col-8 offset-3">
        <h3><%= project.name %></h3>
      </div>
      <div class="card col-6 offset-3 show-card project-card">
        <img src="<%= project.image.url %>" class="card-img-top show-img" alt="Project_image">
        <div class="card-body">
          <p class="card-text"><%= project.description %> </p>
          <p class="card-text">&#8377; <%= project.totalBudget.toLocaleString("en-in") %> </p>
          <p class="card-text"><%= project.location %> </p>
          <p class="card-text">Start date :<%= project.createdAt.toString().split("").slice(4, 15).join("") %> </p>
          <p class="card-text">End date :<%= project.updatedAt.toString().split("").slice(4, 15).join("") %> </p>
        </div>
      </div>
      <br />
      <div class="btns">
        <% if(currUser.role == "Admin" || currUser.role == "Project_Manager" ) { %>
        <a href="/project/<%= project._id %>/edit" class="btn btn-dark col-1 offset-3 edit-btn"> Edit</a>
        <form method="POST" action="/project/<%= project._id %>?_method=DELETE">
          <button class="btn btn-dark offset-5 ">Delete</button>
        </form>
        <% } %>
      </div>
    </div>
</body>